          "render_layer": "transparent",
          "depth_test": true,
          "depth_write": false,
          "src_color": "one",
          "dst_color": "one_minus_src_alpha"
        }
      ]
    },
    { "type": "oit",         "enabled": true },
    { "type": "manipulator", "enabled": true }
  ]
