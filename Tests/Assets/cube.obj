# Unit-test cube — 8 unique vertices, 12 triangles (2 per face × 6 faces).
# Vertex coordinates range [-1, 1] on all axes.

v -1.0 -1.0 -1.0
v  1.0 -1.0 -1.0
v  1.0  1.0 -1.0
v -1.0  1.0 -1.0
v -1.0 -1.0  1.0
v  1.0 -1.0  1.0
v  1.0  1.0  1.0
v -1.0  1.0  1.0

# Front (-Z)
f 1 3 2
f 1 4 3
# Back (+Z)
f 5 6 7
f 5 7 8
# Left (-X)
f 1 5 8
f 1 8 4
# Right (+X)
f 2 3 7
f 2 7 6
# Bottom (-Y)
f 1 2 6
f 1 6 5
# Top (+Y)
f 4 7 3
f 4 8 7
